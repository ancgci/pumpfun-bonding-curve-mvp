{
  "name": "shyft",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "prepare": "husky",
    "start": "NODE_OPTIONS='--max-old-space-size=8192' npx ts-node index.ts",
    "start:dashboard-api": "cd dashboard-api && npx ts-node server.ts",
    "start:dashboard-ui": "cd dashboard && npm run dev",
    "start:all": "concurrently -n \"BOT,API,UI\" -c \"blue,green,magenta\" \"npm start\" \"npm run start:dashboard-api\" \"npm run start:dashboard-ui\"",
    "build": "npx tsc",
    "health": "npx ts-node healthCheck.ts",
    "typecheck": "npx tsc --noEmit",
    "test:metadata": "npx ts-node testMetadata.ts",
    "test:all": "npx ts-node testAllImprovements.ts",
    "test:single-trade": "npx ts-node testSingleTrade.ts",
    "test:trade-type": "npx ts-node testTradeTypeFilter.ts",
    "test:meteora-dbc": "npx ts-node testMeteoraDBC.ts",
    "test:bonk-fun": "npx ts-node testBonkFun.ts",
    "test:daos-fun": "npx ts-node testDaosFun.ts",
    "test:moonshot": "npx ts-node testMoonshot.ts",
    "test:anoncoin": "npx ts-node testAnoncoin.ts",
    "test:real-trading": "npx ts-node testRealTrading.ts",
    "test:specific-token": "npx ts-node testSpecificToken.ts",
    "test:stop-loss": "npx ts-node testStopLossConfig.ts",
    "test:stop-loss-full": "npx ts-node testStopLossFull.ts",
    "backtest": "npx ts-node tools/backtest-telegram.ts",
    "backtest:1h": "npx ts-node tools/backtest-telegram.ts --period 1h",
    "backtest:6h": "npx ts-node tools/backtest-telegram.ts --period 6h",
    "backtest:12h": "npx ts-node tools/backtest-telegram.ts --period 12h",
    "backtest:24h": "npx ts-node tools/backtest-telegram.ts --period 24h",
    "backtest:7d": "npx ts-node tools/backtest-telegram.ts --period 7d",
    "skill:list": "npx ts-node tools/import-skill.ts --list",
    "skill:import": "npx ts-node tools/import-skill.ts",
    "skill:delete": "npx ts-node tools/import-skill.ts --delete",
    "test:fast": "npm run typecheck && npm run test:core",
    "test:fast:full": "npm run test:fast && npm run test:ai-agent",
    "test:core": "jest --config jest.config.js test/unit test/integration",
    "test:frontend": "export LD_LIBRARY_PATH=$PWD/.browser_deps/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH && npx playwright test test/e2e",
    "test:qa": "export LD_LIBRARY_PATH=$PWD/.browser_deps/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH && npm run test:fast:full && npm run test:frontend",
    "test:smoke": "npx ts-node test/smokeTest.ts",
    "test:ai-agent": "jest --config jest.config.js test/ai-agent",
    "test:ai-agent:full": "jest --config jest.config.js test/ai-agent/advanced",
    "qa:unit": "jest --config jest.config.js .agents/agents/QAgent/tests/unit",
    "qa:api": "jest --config jest.config.js .agents/agents/QAgent/tests/api",
    "qa:e2e": "npx playwright test .agents/agents/QAgent/tests/e2e",
    "qa:regression": "npx playwright test .agents/agents/QAgent/tests/regression",
    "qa:full": "npm run qa:unit && npm run qa:api && npm run qa:e2e && npm run qa:regression",
    "start:shadow": "ORGANICITY_SHADOW_MODE=true NODE_OPTIONS='--max-old-space-size=8192' npx ts-node index.ts",
    "organicity:report": "npx ts-node tools/organicity-report.ts",
    "organicity:report:fp": "npx ts-node tools/organicity-report.ts -- --fp",
    "organicity:clear": "npx ts-node tools/organicity-report.ts -- --clear"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@degenfrends/solana-rugchecker": "^0.0.16",
    "@jup-ag/api": "^6.0.45",
    "@project-serum/anchor": "^0.26.0",
    "@shyft-to/solana-transaction-parser": "^1.1.17",
    "@solana/buffer-layout": "^4.0.1",
    "@solana/buffer-layout-utils": "^0.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@triton-one/yellowstone-grpc": "^0.4.0",
    "@types/axios": "^0.9.36",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cache": "^4.1.3",
    "@types/node-telegram-bot-api": "^0.64.14",
    "axios": "^1.12.2",
    "better-sqlite3": "^12.6.2",
    "bottleneck": "^2.19.5",
    "bs58": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.1",
    "jito-ts": "^4.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "node-cache": "^5.1.2",
    "node-telegram-bot-api": "^0.66.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "npm run test:fast"
    ]
  }
}