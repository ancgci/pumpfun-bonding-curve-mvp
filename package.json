{
  "name": "shyft",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "start": "npx ts-node index.ts",
    "start:dashboard": "cd dashboard && npx ts-node server.ts",
    "start:all": "concurrently -n \"BOT,DASHBOARD\" -c \"blue,green\" \"npm start\" \"npm run start:dashboard\"",
    "build": "npx tsc",
    "health": "npx ts-node healthCheck.ts",
    "typecheck": "npx tsc --noEmit",
    "test:metadata": "npx ts-node testMetadata.ts",
    "test:all": "npx ts-node testAllImprovements.ts",
    "test:single-trade": "npx ts-node testSingleTrade.ts",
    "test:trade-type": "npx ts-node testTradeTypeFilter.ts",
    "test:meteora-dbc": "npx ts-node testMeteoraDBC.ts",
    "test:bonk-fun": "npx ts-node testBonkFun.ts",
    "test:daos-fun": "npx ts-node testDaosFun.ts",
    "test:moonshot": "npx ts-node testMoonshot.ts",
    "test:anoncoin": "npx ts-node testAnoncoin.ts",
    "test:real-trading": "npx ts-node testRealTrading.ts",
    "test:specific-token": "npx ts-node testSpecificToken.ts",
    "test:stop-loss": "npx ts-node testStopLossConfig.ts",
    "test:stop-loss-full": "npx ts-node testStopLossFull.ts",
    "backtest": "npx ts-node tools/backtest-telegram.ts",
    "backtest:1h": "npx ts-node tools/backtest-telegram.ts --period 1h",
    "backtest:6h": "npx ts-node tools/backtest-telegram.ts --period 6h",
    "backtest:12h": "npx ts-node tools/backtest-telegram.ts --period 12h",
    "backtest:24h": "npx ts-node tools/backtest-telegram.ts --period 24h",
    "backtest:7d": "npx ts-node tools/backtest-telegram.ts --period 7d"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@jup-ag/api": "^6.0.45",
    "@project-serum/anchor": "^0.26.0",
    "@shyft-to/solana-transaction-parser": "^1.1.17",
    "@solana/buffer-layout": "^4.0.1",
    "@solana/buffer-layout-utils": "^0.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@triton-one/yellowstone-grpc": "^0.4.0",
    "@types/axios": "^0.9.36",
    "@types/node-cache": "^4.1.3",
    "axios": "^1.12.2",
    "bottleneck": "^2.19.5",
    "bs58": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jito-ts": "^4.2.1",
    "lodash": "^4.17.21",
    "node-cache": "^5.1.2",
    "node-telegram-bot-api": "^0.66.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}